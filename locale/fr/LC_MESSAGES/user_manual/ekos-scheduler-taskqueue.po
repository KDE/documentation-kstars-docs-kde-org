#: ../../user_manual/ekos-scheduler-taskqueue.rst:154
msgid "Adding Tasks from Templates"
msgstr "Ajouter des tâches à partir de modèles"

#: ../../user_manual/ekos-scheduler-taskqueue.rst:156
msgid "To add a task to your queue:"
msgstr "Pour ajouter une tâche à votre file :"

#: ../../user_manual/ekos-scheduler-taskqueue.rst:158
