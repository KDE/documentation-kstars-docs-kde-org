#: ../../user_manual/kstars-keys.rst:2
msgid "Keyboard Commands"
msgstr "Команди с клавиатурата"

#: ../../user_manual/kstars-keys.rst:7
msgid "Navigation Keys"
msgstr "Клавиши за навигация"

#: ../../user_manual/kstars-keys.rst:10
msgid "Arrow Keys"
msgstr "Клавиши със стрелки"

#: ../../user_manual/kstars-keys.rst:10
msgid ""
"Use the arrow keys to pan the display. Holding down the **Shift** key "
"doubles the scrolling speed."
msgstr ""
"Използвайте клавишите със стрелки, за да местите дисплея. Задържайки "
"натиснат клавиша **Shift** се удвоява скоростта на превъртане."

#: ../../user_manual/kstars-keys.rst:13
msgid "**+** / **-**"
msgstr "**+** / **-**"

#: ../../user_manual/kstars-keys.rst:13
msgid "Zoom In/Out."
msgstr "Увеличаване/Намаляване на мащаба"

#: ../../user_manual/kstars-keys.rst:16
msgid "**Ctrl** + **Z**"
msgstr "**Ctrl** + **Z**"

#: ../../user_manual/kstars-keys.rst:16
msgid "Restore the default Zoom setting."
msgstr "Възстановяване на стандартния мащабиране."

#: ../../user_manual/kstars-keys.rst:19
msgid "**Ctrl** + **Shift** + **Z**"
msgstr "**Ctrl** + **Shift** + **Z**"

#: ../../user_manual/kstars-keys.rst:19
msgid "Zoom to specified field-of-view angle."
msgstr "Мащабира до желания размер на ъгъла на зрителното поле."

#: ../../user_manual/kstars-keys.rst:22
msgid "Center Display on a major Solar System body:"
msgstr "Центриране върху голям обект от Слънчевата система:"

#: ../../user_manual/kstars-keys.rst:24
msgid "**0**: Sun"
msgstr "**0**: Слънце"

#: ../../user_manual/kstars-keys.rst:26
msgid "**1**: Mercury"
msgstr "**1**: Меркурий"

#: ../../user_manual/kstars-keys.rst:28
msgid "**2**: Venus"
msgstr "**2**: Венера"

#: ../../user_manual/kstars-keys.rst:30
msgid "**3**: Moon"
msgstr "**3**: Луна"

#: ../../user_manual/kstars-keys.rst:32
msgid "**4**: Mars"
msgstr "**4**: Марс"

#: ../../user_manual/kstars-keys.rst:34
msgid "**5**: Jupiter"
msgstr "**5**: Юпитер"

#: ../../user_manual/kstars-keys.rst:36
msgid "**6**: Saturn"
msgstr "**6**: Сатурн"

#: ../../user_manual/kstars-keys.rst:38
msgid "**7**: Uranus"
msgstr "**7**: Уран"

#: ../../user_manual/kstars-keys.rst:40
msgid "**8**: Neptune"
msgstr "**8**: Нептун"

#: ../../user_manual/kstars-keys.rst:42
msgid "**0**–**9**"
msgstr "**0**–**9**"

#: ../../user_manual/kstars-keys.rst:42
msgid "**9**: Pluto"
msgstr "**9**: Плутон"

#: ../../user_manual/kstars-keys.rst:45
msgid "**Z**"
msgstr "**Z**"

#: ../../user_manual/kstars-keys.rst:45
msgid ""
"Center the display at the :doc:`Zenith  <ai-zenith>` Point (straight up)."
msgstr ""
"Центрирайте дисплея в точката на :doc:`Зенита <ai-zenith>` (право нагоре)."

#: ../../user_manual/kstars-keys.rst:48
msgid "**N**"
msgstr "**N**"

#: ../../user_manual/kstars-keys.rst:48
msgid "Center the display above the North point on the horizon."
msgstr "Центрирайте дисплея над северната точка на хоризонта."

#: ../../user_manual/kstars-keys.rst:51
msgid "**E**"
msgstr "**E**"

#: ../../user_manual/kstars-keys.rst:51
msgid "Center the display above the East point on the horizon."
msgstr "Центрирайте дисплея над източната точка на хоризонта."

#: ../../user_manual/kstars-keys.rst:54
msgid "**S**"
msgstr "**S**"

#: ../../user_manual/kstars-keys.rst:54
msgid "Center the display above the South point on the horizon."
msgstr "Центрирайте дисплея над южната точка на хоризонта."

#: ../../user_manual/kstars-keys.rst:57
msgid "**W**"
msgstr "**W**"

#: ../../user_manual/kstars-keys.rst:57
msgid "Center the display above the West point on the horizon."
msgstr "Центрирайте дисплея над западната точка на хоризонта."

#: ../../user_manual/kstars-keys.rst:60
msgid "**Ctrl** + **T**"
msgstr "**Ctrl** + **T**"

#: ../../user_manual/kstars-keys.rst:60
msgid "Toggle tracking mode."
msgstr "Превключване на проследяването."

#: ../../user_manual/kstars-keys.rst:63
msgid "**<**"
msgstr "**<**"

#: ../../user_manual/kstars-keys.rst:63
msgid "Advance the simulation clock backwards by one time step."
msgstr "Преместване на часовника на симулацията с една времева стъпка назад."

#: ../../user_manual/kstars-keys.rst:66
msgid "**>**"
msgstr "**>**"

#: ../../user_manual/kstars-keys.rst:66
msgid "Advance the simulation clock forwards by one time step."
msgstr "Преместване на часовника на симулацията с една времева стъпка напред."

#: ../../user_manual/kstars-keys.rst:71
msgid "Menu Shortcuts"
msgstr "Меню Клавишни комбинации"

#: ../../user_manual/kstars-keys.rst:74
msgid "**Ctrl** + **N**"
msgstr "**Ctrl** + **N**"

#: ../../user_manual/kstars-keys.rst:74
msgid "Download extra data."
msgstr "Изтегляне на допълнителни данни."

#: ../../user_manual/kstars-keys.rst:77
msgid "**Ctrl** + **O**"
msgstr "**Ctrl** + **O**"

#: ../../user_manual/kstars-keys.rst:77
msgid "Open a FITS image in the FITS Editor."
msgstr "Отваряне на FITS изображение във визуализатора на FITS."

#: ../../user_manual/kstars-keys.rst:80
msgid "**Ctrl** + **I**"
msgstr "**Ctrl** + **I**"

#: ../../user_manual/kstars-keys.rst:80
msgid "Export sky image to a file."
msgstr "Експортиране на изображението на небето във файл."

#: ../../user_manual/kstars-keys.rst:83
msgid "**Ctrl** + **L**"
msgstr "**Ctrl** + **L**"

#: ../../user_manual/kstars-keys.rst:83
msgid "Run a KStars :doc:`Observation Planner  <tool-obsplanner>`."
msgstr ""
"Стартиране на :doc:`Планиране на наблюдения (Observation Planner) <tool-"
"obsplanner>` в KStars."

#: ../../user_manual/kstars-keys.rst:86
msgid "**Ctrl** + **Shift** + **P**"
msgstr "**Ctrl** + **Shift** + **P**"

#: ../../user_manual/kstars-keys.rst:86
msgid "Open the Imaging Planner tool."
msgstr "Отваряне на инструмента за планиране на изображения."

#: ../../user_manual/kstars-keys.rst:89
msgid "**Ctrl** + **R**"
msgstr "**Ctrl** + **R**"

#: ../../user_manual/kstars-keys.rst:89
msgid "Run a KStars D-Bus script."
msgstr "Изпълняване на DBus скрипт на KStars."

#: ../../user_manual/kstars-keys.rst:92
msgid "**Ctrl** + **P**"
msgstr "**Ctrl** + **P**"

#: ../../user_manual/kstars-keys.rst:92
msgid "Print the current sky map."
msgstr "Отпечатване на небесната карта"

#: ../../user_manual/kstars-keys.rst:95
msgid "**Ctrl** + **Q**"
msgstr "**Ctrl** + **Q**"

#: ../../user_manual/kstars-keys.rst:95
msgid "Quit KStars."
msgstr "Изход от KStars."

#: ../../user_manual/kstars-keys.rst:98
msgid "**Ctrl** + **E**"
msgstr "**Ctrl** + **E**"

#: ../../user_manual/kstars-keys.rst:98
msgid "Sync the simulation clock with the current system time."
msgstr "Синхронизиране на времето на симулацията с текущото системно време."

#: ../../user_manual/kstars-keys.rst:101
msgid "**Ctrl** + **S**"
msgstr "**Ctrl** + **S**"

#: ../../user_manual/kstars-keys.rst:101
msgid "Set the simulation clock to a specified Time and Date."
msgstr "Задаване на определена дата и час на часовника на симулацията."

#: ../../user_manual/kstars-keys.rst:104
msgid "**Ctrl** + **Shift** + **F**"
msgstr "**Ctrl** + **Shift** + **F**"

#: ../../user_manual/kstars-keys.rst:104
msgid "Toggle full-screen mode."
msgstr "Включване/изключване на пълноекранен режим."

#: ../../user_manual/kstars-keys.rst:107
msgid "**Ctrl** + **0**"
msgstr "**Ctrl** + **0**"

#: ../../user_manual/kstars-keys.rst:107
msgid ""
"Define equipment (telescope, eyepiece, lens and filter) characteristics for "
"observation logs."
msgstr ""
"Определете характеристиките на оборудването (телескоп, окуляр, леща и "
"филтър) за дневниците на наблюдение."

#: ../../user_manual/kstars-keys.rst:110
msgid "**Ctrl** + **1**"
msgstr "**Ctrl** + **1**"

#: ../../user_manual/kstars-keys.rst:110
msgid "Add a new observer item for your observation logs."
msgstr "Добавете нов записи към вашите дневници за наблюдение."

#: ../../user_manual/kstars-keys.rst:113
msgid "**Space**"
msgstr "**Интервал**"

#: ../../user_manual/kstars-keys.rst:113
msgid ""
"Toggle between the :ref:`Horizontal  <ai-skycoords-horizontal>` and :ref:"
"`Equatorial  <ai-skycoords-equatorial>` :doc:`Coordinate Systems  <ai-"
"skycoords>`."
msgstr ""
"Превключване между :ref:`Хоризонтална <ai-skycoords-horizontal>` и :ref:"
"`Екваториална <ai-skycoords-equatorial>` :doc:`координатна система <ai-"
"skycoords>`."

#: ../../user_manual/kstars-keys.rst:116
msgid "**F1**"
msgstr "**F1**"

#: ../../user_manual/kstars-keys.rst:116
msgid "Open the KStars Handbook."
msgstr "Отваряне на Ръководство на KStars."

#: ../../user_manual/kstars-keys.rst:119
msgid ""
"Switch sky chart view to the `Lambert azimuthal equal-area <https://en."
"wikipedia.org/wiki/Lambert_azimuthal_equal-area_projection>`__ projection."
msgstr ""
"Превключете изгледа на небесната карта към `азимуталната равноповърхностна "
"проекция на Lambert <https://en.wikipedia.org/wiki/Lambert_azimuthal_equal-"
"area_projection>`__ "

#: ../../user_manual/kstars-keys.rst:120
msgid "**F5**"
msgstr "**F5**"

#: ../../user_manual/kstars-keys.rst:123
msgid "**F6**"
msgstr "**F6**"

#: ../../user_manual/kstars-keys.rst:123
msgid ""
"Switch sky chart view to the `azimuthal equidistant <https://en.wikipedia."
"org/wiki/Azimuthal_equidistant_projection>`__ projection."
msgstr ""
"Превключете изгледа на небесната карта към `азимутална еквидистантна "
"проекция <https://en.wikipedia.org/wiki/Azimuthal_equidistant_projection>`__."

#: ../../user_manual/kstars-keys.rst:126
msgid "**F7**"
msgstr "**F7**"

#: ../../user_manual/kstars-keys.rst:126
msgid ""
"Switch sky chart view to the `orthographic <https://en.wikipedia.org/wiki/"
"Orthographic_projection_(cartography)>`__ projection."
msgstr ""
"Превключете изгледа на небесна карта към `ортографска проекция <https://en."
"wikipedia.org/wiki/Orthographic_projection_(cartography)>`__."

#: ../../user_manual/kstars-keys.rst:129
msgid ""
"Switch sky chart view to the `equirectangular <https://en.wikipedia.org/wiki/"
"Equirectangular_projection>`__ projection."
msgstr ""
"Превключете изгледа на небесната карта към `равноъгълна проекция <https://en."
"wikipedia.org/wiki/Equirectangular_projection>`__."

#: ../../user_manual/kstars-keys.rst:130
msgid "**F8**"
msgstr "**F8**"

#: ../../user_manual/kstars-keys.rst:133
msgid "**F9**"
msgstr "**F9**"

#: ../../user_manual/kstars-keys.rst:133
msgid ""
"Switch sky chart view to the `stereographic <https://en.wikipedia.org/wiki/"
"Stereographic_projection>`__ projection."
msgstr ""
"Превключете изгледа на небесната карта към `стереографска проекция <https://"
"en.wikipedia.org/wiki/Stereographic_projection>`__."

#: ../../user_manual/kstars-keys.rst:136
msgid "**F10**"
msgstr "**F10**"

#: ../../user_manual/kstars-keys.rst:136
msgid ""
"Switch sky chart view to the `gnomonic <https://en.wikipedia.org/wiki/"
"Gnomonic_projection>`__ projection."
msgstr ""
"Превключете изгледа на небесната карта към` гномоничната проекция<https://en."
"wikipedia.org/wiki/Gnomonic_projection>`__."

#: ../../user_manual/kstars-keys.rst:141
msgid "Actions for the Selected Object"
msgstr "Действия за избрания обект"

#: ../../user_manual/kstars-keys.rst:143
msgid ""
"Each of the following keystrokes performs an action on the *selected "
"object*. The selected object is the last object which was clicked on "
"(identified in the status bar).  Alternatively, if you hold down the "
"**Shift** key, then the action is performed on the centered object instead."
msgstr ""
"Всяко от следните натискания на клавиши изпълнява действие върху избрания "
"обект. Избраният обект е последният обект, върху който е щракнато "
"(идентифициран в лентата на състоянието). Като алтернатива, ако задържите "
"клавиша **Shif** , тогава вместо това действието се извършва върху "
"центрирания обект."

#: ../../user_manual/kstars-keys.rst:146
msgid "**C**"
msgstr "**C**"

#: ../../user_manual/kstars-keys.rst:146
msgid "Center and Track on the selected object."
msgstr "Центриране и проследяване на избрания обект."

#: ../../user_manual/kstars-keys.rst:149
msgid "**D**"
msgstr "**D**"

#: ../../user_manual/kstars-keys.rst:149
msgid "Open the Details window for the selected object."
msgstr "Отваряне на прозорец с подробности за избрания обект."

#: ../../user_manual/kstars-keys.rst:152
msgid "**L**"
msgstr "**L**"

#: ../../user_manual/kstars-keys.rst:152
msgid "Toggle a name label for the selected object."
msgstr "Показване/скриване на надписа с името на центрирания обект"

#: ../../user_manual/kstars-keys.rst:155
msgid "**O**"
msgstr "**O**"

#: ../../user_manual/kstars-keys.rst:155
msgid "Add the selected object to the observing list."
msgstr "Добавя избрания обект към списъка за наблюдение."

#: ../../user_manual/kstars-keys.rst:158
msgid "**P**"
msgstr "**P**"

#: ../../user_manual/kstars-keys.rst:158
msgid "Open the selected object's popup menu."
msgstr "Отворете изскачащото меню на избрания обект."

#: ../../user_manual/kstars-keys.rst:161
msgid "**T**"
msgstr "**T**"

#: ../../user_manual/kstars-keys.rst:161
msgid "Toggle a trail on the selected object (solar system bodies only)."
msgstr ""
"Показване/скриване на траекторията на избрания обект (само за тела от "
"Слънчевата система)."

#: ../../user_manual/kstars-keys.rst:166
msgid "Tools Shortcuts"
msgstr "Клавишни комбинации за инструментите"

#: ../../user_manual/kstars-keys.rst:169
msgid "**Ctrl** + **F**"
msgstr "**Ctrl** + **F**"

#: ../../user_manual/kstars-keys.rst:169
msgid ""
"Open the :ref:`Find Object window  <skyobjects-finding-objects>`, for "
"specifying a sky object on which to center."
msgstr ""
"Отваря се прозорецът за :ref:`Намиране на обект <skyobjects-finding-"
"objects>`, за да посочите небесен обект, върху който да центрирате."

#: ../../user_manual/kstars-keys.rst:172
msgid "**Ctrl** + **M**"
msgstr "**Ctrl** + **M**"

#: ../../user_manual/kstars-keys.rst:172
msgid ""
"Open the Set Coordinates Manually tool, for specifying RA/Dec or Az/Alt "
"coordinates on which to center. The tool defaults to :doc:`J2000 epoch  <ai-"
"epoch>` for the RA/Dec."
msgstr ""
"Отваря се инструмента `` Ръчно задаване на координати`` за задаване на "
"координати RA/Dec или Az/Alt, по които да се центрира. Инструментът по "
"подразбиране е :doc:`J2000 epoch <ai-epoch>` за RA/Dec."

#: ../../user_manual/kstars-keys.rst:175
msgid "**[**"
msgstr "**[**"

#: ../../user_manual/kstars-keys.rst:175
msgid ""
"Start an Angular Distance measurement at the current mouse cursor position. "
"The angular distance between start and end points is displayed at the "
"endpoint."
msgstr ""
"Започнете измерване на ъглово разстояние от текущата позиция на курсора на "
"мишката. Ъгловото разстояние между началната и крайната точка се показва в "
"крайната точка."

#: ../../user_manual/kstars-keys.rst:178
msgid "**Ctrl** + **G**"
msgstr "**Ctrl** + **G**"

#: ../../user_manual/kstars-keys.rst:178
msgid "Open the :doc:`Set Geographic Location  <config-setgeo>` window."
msgstr ""
"Отваря се прозореца :ref:`Задаване на географско местоположение <config-"
"setgeo>`."

#: ../../user_manual/kstars-keys.rst:181
msgid "**Ctrl** + **C**"
msgstr "**Ctrl** + **C**"

#: ../../user_manual/kstars-keys.rst:181
msgid "Open the :doc:`AstroCalculator  <tool-calculator>`."
msgstr "Отваряне на :doc:`Астрокалкулатор <tool-calculator>`."

#: ../../user_manual/kstars-keys.rst:184
msgid "Open the :doc:`Altitude vs. Time  <tool-altvstime>` tool."
msgstr ""
"Отваряне на инструмента :doc:`Височина спрямо време (Altitude vs. Time) "
"<tool-altvstime>`."

#: ../../user_manual/kstars-keys.rst:185
msgid "**Ctrl** + **A**"
msgstr "**Ctrl** + **A**"

#: ../../user_manual/kstars-keys.rst:188
msgid "Open the :doc:`What's up Tonight?  <tool-whatsup>` tool."
msgstr "Отваряне на :doc:`Нещо интересно тази вечер? <tool-whatsup>`."

#: ../../user_manual/kstars-keys.rst:189
msgid "**Ctrl** + **U**"
msgstr "**Ctrl** + **U**"

#: ../../user_manual/kstars-keys.rst:192
msgid "**Ctrl** + **W**"
msgstr "**Ctrl** + **W**"

#: ../../user_manual/kstars-keys.rst:192
msgid "Open the “What's Interesting” tool."
msgstr "Отваряне на инструмента “Нещо интересно”."

#: ../../user_manual/kstars-keys.rst:195
msgid "Open the :doc:`Script Builder  <tool-scriptbuilder>` tool."
msgstr "Отваряне на :doc:`Редактор на скриптове <tool-scriptbuilder>`."

#: ../../user_manual/kstars-keys.rst:196
msgid "**Ctrl** + **B**"
msgstr "**Ctrl** + **B**"

#: ../../user_manual/kstars-keys.rst:199
msgid "**Ctrl** + **Y**"
msgstr "**Ctrl** + **Y**"

#: ../../user_manual/kstars-keys.rst:199
msgid "Open the :doc:`Solar System Viewer  <tool-solarsys>`."
msgstr "Отваряне на :doc:`Преглед на Слънчевата система <tool-solarsys>`."

#: ../../user_manual/kstars-keys.rst:202
msgid "**Ctrl** + **J**"
msgstr "**Ctrl** + **J**"

#: ../../user_manual/kstars-keys.rst:202
msgid "Open the :doc:`Jupiter Moons  <tool-jmoons>` tool."
msgstr "Отваряне на модул :doc:`Луни на Юпитер <tool-jmoons>`."
